{
  "manifest_version": 3,
  "name": "Vinted Achat Auto",
  "version": "2.0",
  "description": "Achat automatique Vinted depuis le vrai Chrome",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.vinted.fr/*",
    "http://localhost:4445/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.vinted.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
